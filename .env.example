# Required: secret for admin API access
ADMIN_SECRET=change-me-to-a-random-string

# Optional: session signing secret (auto-generated if not set, but sessions
# won't survive container restarts without a fixed value)
# SESSION_SECRET=change-me-to-another-random-string

# Optional: public URL for install script references
BASE_URL=http://localhost:8097

# Optional: data retention in hours (default 168 = 7 days)
# RETENTION_HOURS=168

# Optional: database file path (inside container)
DATABASE_PATH=/app/data/labwatch.db
